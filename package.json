{
  "name": "hybrid-model-switcher-mcp",
  "version": "0.2.0",
  "description": "MCP server for routing Claude Desktop workflows to local Ollama models.",
  "type": "module",
  "bin": {
    "hybrid-model-switcher-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node esbuild.config.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src tests --max-warnings=0",
    "start": "node dist/index.js",
    "start:prod": "node dist/production/hybrid-model-switcher-mcp.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "claude",
    "mcp",
    "ollama",
    "local-llm",
    "model-switching"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@sentry/node": "^10.54.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "msw": "^2.14.6",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
